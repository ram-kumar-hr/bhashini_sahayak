# Copy this file to .env and fill in your values

# ── OpenAI (optional — not used when Gemini is configured) ──
OPENAI_API_KEY=

# ── Google Gemini ─────────────────────────────────────────────
# Get a free key at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# ── Qdrant Vector Store ───────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=bhashini_sop

# ── Bhashini / Dhruva API ─────────────────────────
# Get credentials at: https://bhashini.gov.in/ulca/user/register
BHASHINI_API_URL=https://dhruva-api.bhashini.gov.in
BHASHINI_API_KEY=your_bhashini_api_key_here
BHASHINI_USER_ID=your_bhashini_user_id_here
# IndicTrans2 service for translation (from Dhruva model catalogue)
BHASHINI_TRANSLATION_SERVICE_ID=ai4bharat/indictrans-v2-all-gpu--t4

# ── Ticketing (SQLite) ────────────────────────────
TICKETING_DB=./tickets.db

# ── FastAPI Server ────────────────────────────────
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000

# ── RAG Settings ──────────────────────────────────
# Minimum cosine similarity score to consider a result relevant (0-1)
MIN_RELEVANCE_SCORE=0.60
# Number of top chunks to retrieve per query
TOP_K_RESULTS=4
